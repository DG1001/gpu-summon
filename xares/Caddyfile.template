# gpu-summon Full-Stack Caddyfile
#
# Variables (rendered by onstart.sh via envsubst):
#   ${DOMAIN}             e.g. mybox.duckdns.org
#   ${DUCKDNS_TOKEN}      duckdns API token (used for ACME DNS-01)
#   ${ACME_EMAIL}         contact email for Let's Encrypt
#   ${XARES_BASIC_USER}   HTTP-Basic username
#   ${XARES_BASIC_HASH}   bcrypt hash (Caddy-compatible "$2a$..." format)

{
    email ${ACME_EMAIL}
    acme_dns duckdns ${DUCKDNS_TOKEN}
}

# ---------------------------------------------------------------------------
# Apex: xaresaicoder frontend + API. Behind HTTP Basic Auth so the public
# endpoint isn't open. xares-nginx listens on host port 80 (mapped from the
# nginx container by xaresaicoder's docker-compose).
#
# /api/health is exempted from BasicAuth so summon.py's readiness probe
# (and any external monitoring) can hit it anonymously.
# ---------------------------------------------------------------------------
${DOMAIN} {
    @health path /api/health
    handle @health {
        reverse_proxy 127.0.0.1:80
    }

    handle {
        basicauth {
            ${XARES_BASIC_USER} ${XARES_BASIC_HASH}
        }
        reverse_proxy 127.0.0.1:80
    }
}

# ---------------------------------------------------------------------------
# Subdomains: workspace UUIDs go to xares-nginx (which has its own regex
# router for workspace-<uuid>). The carve-out for `llm.${DOMAIN}` lets
# opencode hit llama-server directly without the BasicAuth challenge ---
# llama-server has its own Bearer-Token auth.
#
# ${DOMAIN}'s wildcard cert is automatically requested by Caddy on first
# request that hits an unknown subdomain, so no manual on_demand needed
# (DNS-01 with duckdns supports wildcards, *.${DOMAIN} works in one cert).
# ---------------------------------------------------------------------------
*.${DOMAIN} {
    @llm host llm.${DOMAIN}
    handle @llm {
        reverse_proxy 127.0.0.1:8080
    }

    @workspace host_regexp ^[a-f0-9-]+(-[0-9]+)?\.${DOMAIN}$
    handle @workspace {
        basicauth {
            ${XARES_BASIC_USER} ${XARES_BASIC_HASH}
        }
        reverse_proxy 127.0.0.1:80
    }

    handle {
        respond "unknown subdomain" 404
    }
}
