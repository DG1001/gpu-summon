# gpu-summon code-server Caddyfile
#
# Variables (rendered by onstart.sh via envsubst):
#   ${DOMAIN}         e.g. mybox.duckdns.org
#   ${DUCKDNS_TOKEN}  duckdns API token (used for ACME DNS-01)
#   ${ACME_EMAIL}     contact email for Let's Encrypt
#
# Auth model:
#   - Apex: code-server's own login page (PASSWORD env). No Caddy basicauth.
#   - llm subdomain: llama-server's Bearer-token. No Caddy basicauth (would
#     force opencode to send two credentials).
#
# Single combined site block for apex + wildcard. This is intentional:
# duckdns can only hold ONE TXT record value at _acme-challenge.${DOMAIN}.
# With separate site blocks, Caddy fired two parallel ACME challenges that
# overwrote each other's TXT records ("Incorrect TXT record \"\" found").
# One combined SAN cert = one ACME challenge per renewal = no race.
# Bonus: halves our LE rate-limit footprint (one cert/launch instead of two).

{
    email ${ACME_EMAIL}
}

# Combined apex + wildcard SAN cert. Routes are dispatched by host matchers
# inside the block so apex/llm/port-forward go to the right upstream.
#
# propagation_timeout -1 disables Caddy's self-check that the TXT record
# has propagated (the check tries TCP/53 to duckdns' authoritative NS,
# which vast.ai hosts often firewall). propagation_delay 60s waits a fixed
# block instead, then asks the ACME server to validate. duckdns is fast
# enough that 60s is comfortable.
${DOMAIN}, *.${DOMAIN} {
    tls {
        dns duckdns ${DUCKDNS_TOKEN}
        propagation_delay 60s
        propagation_timeout -1
    }

    # Apex: code-server. Caddy's reverse_proxy already forwards
    # X-Forwarded-* headers correctly by default; we only override Host so
    # code-server sees the original (Caddy otherwise rewrites Host to the
    # upstream's address).
    @apex host ${DOMAIN}
    handle @apex {
        reverse_proxy 127.0.0.1:8443 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # llm.${DOMAIN} -> llama-server :8080 (Bearer-token auth at app level)
    @llm host llm.${DOMAIN}
    handle @llm {
        reverse_proxy 127.0.0.1:8080
    }

    # <port>.${DOMAIN} -> port-forward to 127.0.0.1:<port> for Flask/Vite/
    # FastAPI/etc. running in the IDE terminal. Relative URLs in the app's
    # HTML stay correct -- unlike code-server's path-based /proxy/<port>/.
    #
    # IMPORTANT: must use a DOT (e.g. 5000.${DOMAIN}), not a HYPHEN -- duckdns
    # wildcards work for `*.<your-name>.duckdns.org` (third-level), not for
    # sibling names like `<x>-<your-name>.duckdns.org`.
    #
    # header_regexp matches the raw Host header (port included), unlike the
    # `host` matcher which strips the port. Optional `:<digits>` tail covers
    # vast.ai's random host port.
    @portfwd header_regexp portfwd Host ^([0-9]+)\.${DOMAIN}(:[0-9]+)?$
    handle @portfwd {
        reverse_proxy 127.0.0.1:{re.portfwd.1}
    }

    handle {
        respond "unknown subdomain" 404
    }
}
