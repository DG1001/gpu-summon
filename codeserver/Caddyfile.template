# gpu-summon code-server Caddyfile
#
# Variables (rendered by onstart.sh via envsubst):
#   ${DOMAIN}         e.g. mybox.duckdns.org
#   ${DUCKDNS_TOKEN}  duckdns API token (used for ACME DNS-01)
#   ${ACME_EMAIL}     contact email for Let's Encrypt
#
# Single wildcard cert for *.${DOMAIN} covers ALL three URL patterns we
# expose:
#   - code.${DOMAIN}   IDE (code-server)
#   - llm.${DOMAIN}    llama-server
#   - <port>.${DOMAIN} per-app port forwarding
#
# We deliberately do NOT use the apex (${DOMAIN} without subdomain prefix)
# because:
#   1. apex needs its own cert (wildcard *.foo doesn't cover foo)
#   2. duckdns can only hold ONE TXT record per name -- two parallel ACME
#      DNS-01 challenges for apex + wildcard race and overwrite each
#      other ("Incorrect TXT record \"\" found"), making the launch flaky
#   3. each cert counts against LE's "5 duplicate certs/week" limit. With
#      one cert we get 5 launches per rolling 168h before LE blocks us;
#      with two we got 2.5
#
# Auth model:
#   - code.${DOMAIN}: code-server's own login page (PASSWORD env)
#   - llm.${DOMAIN}: llama-server's Bearer-token (don't add basicauth on
#     top -- would force opencode to send two credentials)

{
    email ${ACME_EMAIL}
    # Force ZeroSSL as the primary (and only) ACME CA. Caddy's default
    # is Let's Encrypt with ZeroSSL as fallback, but Caddy stays in LE
    # retry-backoff for up to 30 days before falling through -- which
    # bricks every launch once the LE 5-duplicate-certs/week limit is
    # hit (it's per identifier-set and the same xaicoder.duckdns.org +
    # *.xaicoder.duckdns.org pair gets reissued each launch). ZeroSSL
    # has its own limits but they're per-account and we provision a
    # fresh account auto-EAB on each container -- no shared bucket.
    # Caddy has a special case in CertMagic that auto-fetches EAB
    # credentials when the CA URL is acme.zerossl.com.
    acme_ca https://acme.zerossl.com/v2/DV90
}

# Single wildcard site block. All routes dispatched by host matcher.
#
# propagation_timeout -1 disables Caddy's self-check that the TXT record
# has propagated (the check tries TCP/53 to duckdns' authoritative NS,
# which vast.ai hosts often firewall). propagation_delay 60s waits a
# fixed block instead, then asks the ACME server to validate. duckdns is
# fast enough that 60s is comfortable.
*.${DOMAIN} {
    tls {
        dns duckdns ${DUCKDNS_TOKEN}
        propagation_delay 60s
        propagation_timeout -1
    }

    # code.${DOMAIN} -> code-server :8443 (IDE).
    # We override Host so code-server sees the original hostname (Caddy
    # otherwise rewrites Host to the upstream's address). X-Real-IP/
    # X-Forwarded-* are forwarded by reverse_proxy by default.
    @code host code.${DOMAIN}
    handle @code {
        reverse_proxy 127.0.0.1:8443 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # llm.${DOMAIN} -> llama-server :8080 (Bearer-token at app level)
    @llm host llm.${DOMAIN}
    handle @llm {
        reverse_proxy 127.0.0.1:8080
    }

    # <port>.${DOMAIN} -> port-forward to 127.0.0.1:<port> for Flask/Vite/
    # FastAPI/etc. running in the IDE terminal. Relative URLs in the app's
    # HTML stay correct -- unlike code-server's path-based /proxy/<port>/.
    #
    # IMPORTANT: must use a DOT (e.g. 5000.${DOMAIN}), not a HYPHEN -- duckdns
    # wildcards work for `*.<your-name>.duckdns.org` (third-level), not for
    # sibling names like `<x>-<your-name>.duckdns.org`.
    #
    # header_regexp matches the raw Host header (port included), unlike the
    # `host` matcher which strips the port. Optional `:<digits>` tail covers
    # vast.ai's random host port.
    @portfwd header_regexp portfwd Host ^([0-9]+)\.${DOMAIN}(:[0-9]+)?$
    handle @portfwd {
        reverse_proxy 127.0.0.1:{re.portfwd.1}
    }

    handle {
        respond "unknown subdomain" 404
    }
}
