# gpu-summon code-server Caddyfile
#
# Variables (rendered by onstart.sh via envsubst):
#   ${DOMAIN}         e.g. mybox.duckdns.org
#   ${DUCKDNS_TOKEN}  duckdns API token (used for ACME DNS-01)
#   ${ACME_EMAIL}     contact email for Let's Encrypt
#
# Auth model:
#   - Apex: code-server's own login page (PASSWORD env). No Caddy basicauth.
#   - llm subdomain: llama-server's Bearer-token. No Caddy basicauth (would
#     force opencode to send two credentials).

{
    email ${ACME_EMAIL}
}

# ACME DNS-01 config snippet -- imported by both site blocks.
#
# propagation_timeout -1 disables Caddy's self-check that the TXT record
# has propagated (the check tries TCP/53 to duckdns' authoritative NS,
# which vast.ai hosts often firewall -- one of our painful lessons).
# propagation_delay 60s waits a fixed block instead, then asks the ACME
# server to validate. duckdns is fast enough that 60s is comfortable.
#
# Without this snippet, fresh launches randomly take 5-10 minutes for
# Caddy to fall through LE-prod -> LE-staging -> ZeroSSL until one
# happens to succeed within the propagation_timeout window.
(acme_dns_config) {
    tls {
        dns duckdns ${DUCKDNS_TOKEN}
        propagation_delay 60s
        propagation_timeout -1
    }
}

# Apex: code-server. Caddy's reverse_proxy already forwards X-Forwarded-*
# headers correctly by default; we only override Host so code-server sees
# the original (Caddy otherwise rewrites Host to the upstream's address).
${DOMAIN} {
    import acme_dns_config
    reverse_proxy 127.0.0.1:8443 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}

# Subdomains:
#   - llm.${DOMAIN}            -> llama-server :8080
#   - <port>.${DOMAIN}         -> port-forward to 127.0.0.1:<port>
#                                 (use this for Flask/React/etc. running
#                                 in code-server's terminal -- relative
#                                 URLs in your app's HTML stay correct,
#                                 unlike code-server's /proxy/<port>/)
#
# IMPORTANT: must use a DOT (e.g. 5000.${DOMAIN}), not a HYPHEN -- duckdns
# wildcards work for `*.<your-name>.duckdns.org` (third-level), not for
# sibling names like `<x>-<your-name>.duckdns.org`.
#
# The regex matches with an optional `:<port>` trailer so it works whether
# the user's URL bar carries the random vast host port or not. Caddy's
# `header_regexp Host` matches the raw Host header (port included), unlike
# the `host` matcher which strips the port.
*.${DOMAIN} {
    import acme_dns_config

    @llm host llm.${DOMAIN}
    handle @llm {
        reverse_proxy 127.0.0.1:8080
    }

    @portfwd header_regexp portfwd Host ^([0-9]+)\.${DOMAIN}(:[0-9]+)?$
    handle @portfwd {
        reverse_proxy 127.0.0.1:{re.portfwd.1}
    }

    handle {
        respond "unknown subdomain" 404
    }
}
